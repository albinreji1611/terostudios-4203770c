	/* ==============================
   Mobile Hamburger Button Styling
   ============================== */

.menu-button.w-nav-button.mobile-nav-toggler {
  position: relative;
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border: none;
  cursor: pointer;
  z-index: 9999;
}

/* Hamburger Lines */
.menu-button.w-nav-button.mobile-nav-toggler .w-icon-nav-menu {
  position: relative;
  width: 26px;
  height: 2px;
  background: #ffffff;
  border-radius: 2px;
  transition: all 0.4s cubic-bezier(0.77, 0.2, 0.05, 1);
}

.menu-button.w-nav-button.mobile-nav-toggler .w-icon-nav-menu::before,
.menu-button.w-nav-button.mobile-nav-toggler .w-icon-nav-menu::after {
  content: "";
  position: absolute;
  left: 0;
  width: 26px;
  height: 2px;
  background: #ffffff;
  border-radius: 2px;
  transition: all 0.4s cubic-bezier(0.77, 0.2, 0.05, 1);
}

.menu-button.w-nav-button.mobile-nav-toggler .w-icon-nav-menu::before {
  top: -8px;
}

.menu-button.w-nav-button.mobile-nav-toggler .w-icon-nav-menu::after {
  top: 8px;
}

/* ==============================
   Animated "X" Effect
   ============================== */
.menu-button.w-nav-button.mobile-nav-toggler.w--open .w-icon-nav-menu {
  background: transparent;
}

.menu-button.w-nav-button.mobile-nav-toggler.w--open .w-icon-nav-menu::before {
  transform: rotate(45deg);
  top: 0;
}

.menu-button.w-nav-button.mobile-nav-toggler.w--open .w-icon-nav-menu::after {
  transform: rotate(-45deg);
  top: 0;
}

/* Optional Hover Effect */
.menu-button.w-nav-button.mobile-nav-toggler:hover .w-icon-nav-menu,
.menu-button.w-nav-button.mobile-nav-toggler:hover .w-icon-nav-menu::before,
.menu-button.w-nav-button.mobile-nav-toggler:hover .w-icon-nav-menu::after {
  background: #e6e6e6;
}
.main-container {
    padding-left: 0px; 
     padding-right: 0px;
}
	li.menu-item .menu-item {
    margin: 0px;
    text-transform: uppercase;
}
