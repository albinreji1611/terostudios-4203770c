    <style>
    .video-modal {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.9);
        display: none; /* Hidden by default */
        z-index: 99999;
        /* Flexbox for perfect centering */
        align-items: center;
        justify-content: center;
    }
    .video-modal-inner {
        position: relative;
        width: 90%;
        max-width: 900px;
        aspect-ratio: 16 / 9; /* Maintains video shape */
    }
    .video-modal iframe {
        width: 100%;
        height: 100%;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }
    .video-close {
        position: absolute;
        top: -45px;
        right: -10px;
        font-size: 40px;
        line-height: 1;
        color: #fff;
        cursor: pointer;
        transition: opacity 0.3s;
    }
    .video-close:hover {
        opacity: 0.7;
    }
    </style>

    <script>
    jQuery(function($){
        // Store the video URL from the iframe src initially
        const videoSrc = $("#showreel-video").attr("src");
        
        // Empty the src on page load so it doesn't play in background
        $("#showreel-video").attr("src", "");

        // OPEN MODAL
        $("a[href='#showreel-modal']").on("click", function(e){
            e.preventDefault();
            // Set the src back (this triggers autoplay)
            $("#showreel-video").attr("src", videoSrc);
            $("#showreel-modal").css("display", "flex").hide().fadeIn();
        });

        // CLOSE MODAL
        $(".video-close, #showreel-modal").on("click", function(e){
            // Close only if clicking background or X
            if(e.target !== this && !$(e.target).hasClass('video-close')) return;
            
            $("#showreel-modal").fadeOut(function(){
                // Wipe the src to stop the video/audio
                $("#showreel-video").attr("src", "");
            });
        });
    });
    </script>
