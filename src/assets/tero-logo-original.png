/* === BASE STYLES FOR FIRST & SECOND LEVEL SUBMENUS === */
.main-menu.w-nav-menu ul.submenu {
  background-color: #1f1f1f !important;
  position: absolute !important;
  top: 100% !important;
  left: 0 !important;
  z-index: 99 !important;
  min-width: 240px !important;
  display: none !important;
  border-radius: 6px !important;
  padding: 0 !important;
  text-align: center !important;
}

.main-menu.w-nav-menu li:hover > ul.submenu {
  display: block !important;
}

/* REMOVE BORDERS TO PREVENT DOUBLE LINES */
.main-menu.w-nav-menu ul.submenu li {
  width: 100% !important;
  display: block !important;
}

/* === SUBMENU LINK STYLING === */
.main-menu.w-nav-menu ul.submenu li > a {
  display: block !important;
  font-size: 16px !important;
  font-weight: 400 !important;
  text-transform: uppercase !important;
  color: #fff !important;
  padding: 14px 20px !important;
  text-decoration: none !important;
  position: relative !important;
  transition: background-color 0.3s ease, color 0.3s ease !important;
  white-space: normal !important;
  text-align: center !important;
}

/* HOVER STYLING */
.main-menu.w-nav-menu ul.submenu li > a:hover {
  background-color: #333 !important;
  color: #f26522 !important;
}

/* === LINE EFFECT - UNIFORM WHITE BY DEFAULT === */
.main-menu.w-nav-menu ul.submenu li > a::before,
.main-menu.w-nav-menu ul.submenu li > a::after {
  content: "" !important;
  position: absolute !important;
  left: 0 !important;
  right: 0 !important;
  height: 2px !important;
  background-color: #fff !important;
  transform: scaleX(1) !important;
  transform-origin: center !important;
  transition: background-color 0.3s ease !important;
}

.main-menu.w-nav-menu ul.submenu li > a::before {
  top: 0 !important;
}
.main-menu.w-nav-menu ul.submenu li > a::after {
  bottom: 0 !important;
}

/* HOVER = ORANGE LINE */
.main-menu.w-nav-menu ul.submenu li > a:hover::before,
.main-menu.w-nav-menu ul.submenu li > a:hover::after {
  background-color: #f26522 !important;
}

/* ACTIVE ITEM STYLING (like MULTIMEDIA) */
.main-menu.w-nav-menu ul.submenu li.current-menu-item > a::after,
.main-menu.w-nav-menu ul.submenu li.current-menu-parent > a::after {
  background-color: #f26522 !important;
}

/* === SECOND LEVEL (RIGHT SIDE FLYOUT) === */
.main-menu.w-nav-menu ul.submenu li > ul.submenu {
  position: absolute !important;
  top: 0 !important;
  left: 100% !important;
  min-width: 240px !important;
  background-color: #1f1f1f !important;
  border-radius: 6px !important;
  display: none !important;
  z-index: 999 !important;
  margin-left: 4px !important;
  text-align: center !important;
}

.main-menu.w-nav-menu ul.submenu li:hover > ul.submenu {
  display: block !important;
}

