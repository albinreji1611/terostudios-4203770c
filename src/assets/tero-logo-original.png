************************
/* Section Background */
.testimonials-section {
    background: #000;
    padding: 80px 0;
    position: relative;
}

/* Carousel Wrapper */
.testimonials-carousel {
    display: flex;
    gap: 25px;
}

/* Testimonial Card */
.testimonial-card {
    background: #2A1E16;
    color: #fff;
    border-radius: 16px;
    padding: 70px 25px 35px;
    width: 360px;
    text-align: center;
    position: relative;
    
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    height: 420px; /* Force equal height */
}

/* Profile Image */
.testimonial-img img {
    width: 90px !important;
    height: 90px !important;
    border-radius: 50%;
    border: 3px solid #EB8A32;
    object-fit: cover;
    position: absolute;
    top: -45px;
    left: 50%;
    transform: translateX(-50%);
}

/* Text Styling */
.testimonial-card h3 {
    font-size: 18px;
    margin: 10px 0 4px;
    font-weight: 700;
}

.designation {
    display: block;
    font-size: 14px;
    opacity: .8;
    margin-bottom: 10px;
}

.testimonial-card p {
    font-size: 15px;
    line-height: 1.5;
    opacity: .9;
    padding: 0 10px;
    margin-top: auto; /* Push text to balance spacing */
}

/* Slick Fix: remove left-right crop */
.slick-list {
    padding: 25px 0 !important;
}

/* Navigation Dots */
.slick-dots li button:before {
    font-size: 10px;
    color: #EB8A32;
    opacity: 0.4;
}

.slick-dots li.slick-active button:before {
    color: #EB8A32;
    opacity: 1;
}
/* Responsive */
@media(max-width: 768px){
    .testimonial-card {
        width: 300px;
        height: 380px;
        padding: 60px 20px 30px;
    }
}
.eael-filter-gallery-control {
    display: none;
}
/* Force EAEL gallery to landscape rectangle */
.eael-gallery-grid-item .gallery-item-thumbnail-wrap img {
    width: 100%;
    height: 220px;
    object-fit: cover;
    border-radius: 10px; /* Optional: clean rounded rectangle */
}

/* Ensure wrapper doesn’t crop wrongly */
.eael-gallery-grid-item .gallery-item-thumbnail-wrap {
    height: auto !important;
}

/* Fix hover caption to respect new shape */
.gallery-item-caption-wrap.card-hover-bg,
.gallery-item-caption-wrap.caption-style-card {
    border-radius: 10px;
}
a.elementor-button.elementor-button-link.elementor-size-sm {
    background-color: #000;
    color: #fff;
    transition: all 0.3s ease;
    border: 2px solid #000;
    position: relative;
    z-index: 1;
}

a.elementor-button.elementor-button-link.elementor-size-sm:hover {
    background-color: #fff;
    color: #000;
}

------
/* General Styling for the Section */
.testimonials-section {
    padding: 50px 0;
    text-align: center;
    font-family: Arial, sans-serif; /* Use your preferred font */
}

/* Container for width control */
.container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 15px;
}

/* Section Title (TESTIMONIALS) */
.section-title {
    font-size: 40px;
    font-weight: bold;
    color: #ff9900; /* Use the orange color from the image */
    margin-bottom: 5px;
    letter-spacing: 1px;
}

/* Subtitle */
.section-subtitle {
    font-size: 16px;
    color: #555;
    margin-bottom: 40px;
}

/* Grid Layout for Testimonial Cards */
.testimonials-grid {
    display: flex;
    gap: 30px; /* Space between cards */
    flex-wrap: wrap; /* Allows wrapping on smaller screens */
    justify-content: center;
}

/* Styling for each Testimonial Card */
.testimonial-card {
    flex: 1; /* Makes cards grow equally */
    max-width: 350px; /* Maximum width for a single card */
    background-color: #f7f7f7; /* Light background for the card */
    padding: 40px 30px;
    border-radius: 8px;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05); /* Subtle shadow */
    position: relative;
    text-align: center;
}

/* Featured Card (Middle One) */
.featured-card {
    background-color: #ffffff; /* White background for the middle card */
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1); /* More pronounced shadow */
    transform: translateY(-10px); /* Lift it slightly */
}

/* Avatar Image */
.avatar {
    width: 100px;
    height: 100px;
    border-radius: 50%; /* Makes it circular */
    object-fit: cover;
    margin-bottom: 20px;
    border: 3px solid #fff; /* White border for contrast */
    box-shadow: 0 0 0 5px #e6e6e6; /* Outer ring effect */
    position: absolute; /* Positioning relative to the card */
    top: -50px; /* Pull it up and out of the card slightly */
    left: 50%;
    transform: translateX(-50%);
}

/* Blockquote for the testimonial text */
.quote {
    font-size: 15px;
    line-height: 1.6;
    color: #444;
    margin: 50px 0 20px; /* Top margin for avatar space */
    font-style: italic;
    padding: 0 10px;
}

/* Large quote marks (optional, but adds visual style) */
.quote-mark {
    font-size: 30px;
    color: #ff9900;
    font-family: serif;
    font-weight: 700;
    display: inline-block;
    margin: 0 5px;
}

/* Client Name */
.client-name {
    font-size: 18px;
    font-weight: bold;
    color: #333;
    margin-bottom: 0px;
    margin-top: 15px; /* Space after quote */
}

/* Client Title/Company */
.client-title {
    font-size: 14px;
    color: #888;
    margin-top: 5px;
}

/* --- Media Queries for Responsiveness --- */
@media (max-width: 1024px) {
    .testimonial-card {
        max-width: 45%; /* Two cards per row on tablets */
    }
}

@media (max-width: 768px) {
    .testimonials-grid {
        flex-direction: column; /* Stacks cards vertically on mobile */
        gap: 60px; /* More space between stacked cards */
    }
    .testimonial-card, .featured-card {
        max-width: 90%;
        margin: 0 auto;
        transform: none; /* Remove the slight lift on mobile */
    }
    .avatar {
        top: -45px; /* Adjust avatar position for stacked cards */
    }
}
@keyframes borderAnimation {
    0% {
        background-position: 0% 50%;
    }
    50% {
        background-position: 100% 50%;
    }
    100% {
        background-position: 0% 50%;
    }
}
}
.contact-us-form .form-row {
    display: flex;
    gap: 30px;
    margin-bottom: 20px;
}

.contact-us-form .form-row > * {
    width: 100%;
}

.contact-us-form .form-full-row {
    margin-top: 20px;
}

.contact-us-form input,
.contact-us-form textarea {
    width: 100%;
    font-size: 16px;
    padding: 12px 0;
    border: none;
    border-bottom: 1px solid #000;
    outline: none;
}

.contact-us-form textarea {
    min-height: 200px;
    resize: vertical;
}

/* Fix CF7 submit button */
.wpcf7 form .wpcf7-submit {
    background: #000;
    color: #fff;
    font-size: 18px;
    padding: 15px 50px;
    border: none;
    border-radius: 40px;
    cursor: pointer;
    display: inline-block;
    transition: all 0.3s ease;
    width: auto;
}

/* Remove theme conflicting styles */
.wpcf7 form input[type="submit"] {
    background: #000 !important;
    box-shadow: none !important;
    border-radius: 40px !important;
    border: none !important;
    padding: 15px 50px !important;
    width: auto !important;
}

/* Align center if needed */
.form-button,
.wpcf7-submit {
    text-align: center;
}

/* On hover */
.wpcf7 form .wpcf7-submit:hover {
    opacity: 0.75;
}

/* Remove weird orange wrapper */
input.wpcf7-submit {
    background-image: none !important;
}
.wpcf7 input:not([type="submit"]) {
    background: transparent;
}

div.form-button,
.wpcf7-form-control-wrap {
    background: transparent !important;
    box-shadow: none !important;
	width:100% !important;
}
span.wpcf7-form-control-wrap {
    color: black;
	font-size:16px !important;
}
/* Responsive form layout */
/* Default desktop layout uses flex (already set earlier) */

@media (max-width: 768px) {
    .contact-us-form .form-row {
        flex-direction: column;
        gap: 20px;
    }
    
    .contact-us-form .form-row > * {
        width: 100% !important;
    }

    .form-full-row textarea {
        min-height: 160px;
    }

    .form-button {
        text-align: left !important; /* or center if you prefer */
        width: 100%;
    }

    .contact-us-form input,
    .contact-us-form textarea {
        font-size: 15px !important;
    }
	.form-button {
    text-align: center !important;
}

}


