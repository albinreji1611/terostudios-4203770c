<script type="text/javascript" src="https://terostudios.com/wp-includes/js/jquery/jquery.min.js?ver=3.7.1" id="jquery-core-js"></script>
<script type="text/javascript" id="jquery-core-js-after">
/* <![CDATA[ */
    jQuery(document).ready(function($){
        $('.tero-item').each(function(){
            var video = $(this).find('video').get(0);
            if(!video) return;
            $(this).on('mouseenter', function(){
                video.currentTime = 0;
                video.play();
            }).on('mouseleave', function(){
                video.pause();
                video.currentTime = 0;
            });
        });
    });
    

        document.addEventListener('DOMContentLoaded', function () {
            const socialMap = {
                youtube: '<i class="fab fa-youtube"></i>',
                instagram: '<i class="fab fa-instagram"></i>',
                x: '<i class="fab fa-x-twitter"></i>',  // X icon (Twitter)
                linkedin: '<i class="fab fa-linkedin-in"></i>'
            };

            document.querySelectorAll('.footer-socials .social-item').forEach(function(item) {
                const textEl = item.querySelector('.social-text-2');
                if (textEl) {
                    const platform = textEl.textContent.trim().toLowerCase();
                    if (socialMap[platform]) {
                        textEl.innerHTML = socialMap[platform];
                    }
                }
            });
        });
    

        document.addEventListener('DOMContentLoaded', function () {
            const socialContainer = document.querySelector('.inner-footer .socials');

            if (socialContainer) {
                const iconsHTML = `
                    <a href="https://www.youtube.com" target="_blank" class="social-item w-inline-block">
                        <div class="social-text-2"><i class="fab fa-youtube"></i></div>
                        <img decoding="async" src="https://terostudios.com/wp-content/themes/darkyn/assets/images/arrow3_1arrow3.png" alt="terostudios.com" class="social-arrow-2">
                    </a>
                    <a href="https://www.instagram.com" target="_blank" class="social-item w-inline-block">
                        <div class="social-text-2"><i class="fab fa-instagram"></i></div>
                        <img decoding="async" src="https://terostudios.com/wp-content/themes/darkyn/assets/images/arrow3_1arrow3.png" alt="terostudios.com" class="social-arrow-2">
                    </a>
                    <a href="https://www.x.com" target="_blank" class="social-item w-inline-block">
                        <div class="social-text-2"><i class="fab fa-x-twitter"></i></div>
                        <img decoding="async" src="https://terostudios.com/wp-content/themes/darkyn/assets/images/arrow3_1arrow3.png" alt="terostudios.com" class="social-arrow-2">
                    </a>
                    <a href="https://www.linkedin.com" target="_blank" class="social-item w-inline-block">
                        <div class="social-text-2"><i class="fab fa-linkedin-in"></i></div>
                        <img decoding="async" src="https://terostudios.com/wp-content/themes/darkyn/assets/images/arrow3_1arrow3.png" alt="terostudios.com" class="social-arrow-2">
                    </a>
                `;
                socialContainer.innerHTML = iconsHTML;
            }
        });
    
//# sourceURL=jquery-core-js-after
/* ]]> */
</script>
