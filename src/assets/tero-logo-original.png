<style id='tero-projects-style-inline-css' type='text/css'>

    .tero-wrapper { max-width:1400px; margin:60px auto; padding:0 18px; }
    .tero-fullwidth .tero-item.fullwidth {
        width:100% !important;
        display:block;
        margin-bottom:40px;
        height:300px;
    }
    .tero-fullwidth .tero-item.fullwidth video,
    .tero-fullwidth .tero-item.fullwidth img {
        width:100%;
        height:100%;
        object-fit:cover;
    }
    @media(max-width:768px){
        .tero-fullwidth .tero-item.fullwidth { height:auto; }
    }

    .tero-masonry {
        column-count: 2;
        column-gap: 30px;
    }
    @media(max-width:768px){ .tero-masonry { column-count: 1; column-gap: 20px; } }

    .tero-item {
        display:inline-block;
        width:100%;
        margin:0 0 30px;
        border-radius:12px;
        overflow:hidden;
        background:#000;
        position:relative;
    }
    .tero-media { position:relative; width:100%; }
    .tero-poster, .tero-video { width:100%; height:auto; display:block; object-fit:cover; transition:opacity .4s ease; }
    .tero-video { position:absolute; top:0; left:0; opacity:0; }
    .tero-item:hover .tero-poster { opacity:0; }
    .tero-item:hover .tero-video { opacity:1; }

    .tero-overlay {
        position:absolute; bottom:0; left:0; right:0;
        padding:26px;
        background:linear-gradient(180deg,rgba(0,0,0,0)0%,rgba(0,0,0,0.6)70%,rgba(0,0,0,0.85)100%);
        color:#fff;
        opacity:0; transform:translateY(10px);
        transition:all .3s ease;
    }
    .tero-item:hover .tero-overlay { opacity:1; transform:translateY(0); }
    .tero-item-title { font-size:26px; font-weight:700; margin:0 0 6px; }
    .tero-creative-details { font-size:14px; opacity:0.9; }
    .tero-view-link { font-size:13px; margin-top:10px; display:inline-block; }
    
/*# sourceURL=tero-projects-style-inline-css */
</style>
